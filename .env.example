# Ailovanta currently uses a local bootstrap runtime for chat inference.
# This is not Alibaba Cloud, DashScope, or a production Ailovanta-owned model.
# The Ailovanta-owned model path starts after public/core bridge + trained artifact promotion.

AILOVANTA_MODEL_STAGE=bootstrap_local_runtime
AILOVANTA_OWNED_MODEL_READY=false

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT_SECONDS=30
