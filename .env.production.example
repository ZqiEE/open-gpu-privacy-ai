# Ailovanta production environment example
# Copy to your deployment secret manager. Do not commit real secrets.

AILOVANTA_ENV=production
AILOVANTA_PUBLIC_BASE_URL=https://your-domain.example

# Artifact storage
# local is for demo only. Use external adapter implementation for production.
AILOVANTA_ARTIFACT_STORE=local
AILOVANTA_ARTIFACT_STORE_URI=runtime_data/artifacts

# Chain / anchor adapter
# file is local append-only log. Replace with a real chain or durable external anchor adapter later.
AILOVANTA_CHAIN_ANCHOR=file
AILOVANTA_CHAIN_ANCHOR_URI=runtime_data/anchors

# Worker / model backend
AILOVANTA_WORKER_MODE=remote
AILOVANTA_MODEL_BACKEND=remote

# Runtime stores
AILOVANTA_NODE_TRUST_PATH=runtime_data/node_trust.sqlite3
AILOVANTA_RUNTIME_PATH=runtime_data/runtime.sqlite3
AILOVANTA_ROUTE_BOOK_PATH=runtime_data/route_book.sqlite3

# Node proof policy
AILOVANTA_REQUIRE_NODE_PROOF=true
AILOVANTA_MIN_PROOF_COVERAGE=0.8
AILOVANTA_MIN_AVG_TRUST_SCORE=0.75

# Abuse controls
AILOVANTA_RATE_LIMIT_ENABLED=true
AILOVANTA_RATE_LIMIT_PER_MINUTE=120
AILOVANTA_RATE_LIMIT_WINDOW_SECONDS=60

# Secrets are examples only. Put real values in your deployment secret manager.
# AILOVANTA_ADMIN_TOKEN=replace-me
# AILOVANTA_NODE_SECRETS_JSON={"node-1":"replace-me"}
# AILOVANTA_EXTERNAL_ARTIFACT_TOKEN=replace-me
# AILOVANTA_CHAIN_PRIVATE_KEY=replace-me
